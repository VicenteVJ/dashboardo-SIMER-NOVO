{
  "name": "dashboard-simer",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "netlify dev --filter @simer/client",
    "dev:local": "concurrently -n API,WEB -c blue,magenta \"npm run dev --workspace server\" \"npm run dev --workspace client\"",
    "start": "npm run start --workspace server",
    "build": "npm run build --workspace client",
    "test": "npm run test --workspace server",
    "check": "npm run test && npm run build"
  },
  "dependencies": {
    "@netlify/blobs": "^10.7.9",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "multer": "^2.0.2",
    "serverless-http": "^4.0.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "netlify-cli": "^26.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
